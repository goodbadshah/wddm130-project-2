<%- include('partials/header') %>

<div class="page-hero">
    <h1>Student Service Portal</h1>
    <p>Submit and track service requests from the JustAnother College Student Services Office.</p>
</div>

<div class="content-card">
    <h2>Available Services</h2>
    <p>The following services can be requested through this portal. Fill out the request form and we'll follow up based on your chosen contact method.</p>

    <table class="services-table">
        <thead>
            <tr>
                <th>Service</th>
                <th>Estimated Response</th>
                <th>Fee</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>ID Card Replacement</td>
                <td>1 – 3 business days</td>
                <td>$25.00</td>
            </tr>
            <tr>
                <td>Enrollment Letter</td>
                <td>2 – 3 business days</td>
                <td>$10.00</td>
            </tr>
            <tr>
                <td>Timetable Help / Academic Support</td>
                <td>Same day or next business day</td>
                <td>No charge</td>
            </tr>
        </tbody>
    </table>
</div>

<div class="content-card">
    <h2>How It Works</h2>
    <ol class="steps-list">
        <li>Fill out the service request form with your student information.</li>
        <li>Upload a photo of your student card as supporting documentation.</li>
        <li>Submit the form — you'll receive a confirmation page with your request number.</li>
        <li>A staff member will contact you using your preferred contact method.</li>
    </ol>
    <a href="/request" class="btn-primary">Submit a Request</a>
</div>

<%- include('partials/footer') %>
